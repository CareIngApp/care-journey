# Care Journey - environment template. Copy to .env.local for local dev,
# and set the same vars in Vercel (Project Settings -> Environment Variables).
# Leave the save vars unset to run fully stateless (the default).

# --- Saved-account layer (off by default) ---
# Turn the saved layer on only when: DPIA signed, Supabase project ready, SSO wired.
NEXT_PUBLIC_CJ_SAVE=0

# Care Journey Supabase project (EU, eu-west-1). Separate from CFG and the website.
# Both are public/anon values, safe to expose to the browser. RLS protects the data.
NEXT_PUBLIC_SUPABASE_URL_CJ=
NEXT_PUBLIC_SUPABASE_ANON_KEY_CJ=
